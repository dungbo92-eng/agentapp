{
  "name": "agent-app",
  "version": "0.17.4",
  "private": true,
  "description": "Multi-agent development orchestrator foundation",
  "author": "AgentApp Contributors",
  "main": "apps/desktop/main.mjs",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "agent:pull": "node scripts/claude-sync.mjs --pull --verbose",
    "agent:push": "node scripts/claude-sync.mjs --push --verbose",
    "agent:sync": "node scripts/claude-sync.mjs --auto --verbose",
    "agent:status": "node scripts/claude-sync.mjs --status",
    "agent:budget": "node scripts/agent-budget.mjs",
    "agent:claude-prompt": "node scripts/agent-worker-prompt.mjs --worker claude-code --format claude-code",
    "agent:codex-prompt": "node scripts/agent-worker-prompt.mjs --worker codex --format codex",
    "agent:cursor-prompt": "node scripts/agent-worker-prompt.mjs --worker cursor --format cursor",
    "agent:doctor": "node scripts/agent-doctor.mjs",
    "agent:dry-run": "node scripts/agent-dry-run.mjs",
    "agent:fallback": "node scripts/agent-handoff-only.mjs",
    "agent:next": "node scripts/agent-next.mjs",
    "agent:prompt": "node scripts/agent-worker-prompt.mjs",
    "agent:progress": "node scripts/agent-progress.mjs",
    "agent:route": "node scripts/agent-route-model.mjs",
    "agent:scheduled-check": "node scripts/agent-scheduled-check.mjs",
    "agent:setup": "node scripts/agent-environment-setup.mjs",
    "agent:cycle-test": "node scripts/user-environment-cycle-test.mjs",
    "agent:report": "node scripts/agent-report.mjs",
    "agent:ponytail": "node scripts/integrate-ponytail.mjs",
    "dashboard:prepare": "node scripts/dashboard-prepare.mjs",
    "dashboard:dev": "pnpm dashboard:prepare && pnpm --dir apps/dashboard dev",
    "dashboard:build": "pnpm dashboard:prepare && pnpm --dir apps/dashboard build",
    "desktop:serve": "pnpm dashboard:build && node scripts/dashboard-server.mjs",
    "desktop:dev": "pnpm dashboard:build && electron apps/desktop/main.mjs",
    "desktop:pack": "pnpm dashboard:build && electron-builder --win portable --x64",
    "desktop:installer": "pnpm dashboard:build && electron-builder --win nsis --x64",
    "desktop:all": "pnpm dashboard:build && electron-builder --win portable nsis --x64",
    "desktop:artifact": "node scripts/desktop-artifact-info.mjs",
    "desktop:release": "node scripts/desktop-release.mjs",
    "desktop:publish": "node scripts/desktop-publish.mjs",
    "claude:pull": "node scripts/claude-sync.mjs --pull --verbose",
    "claude:push": "node scripts/claude-sync.mjs --push --verbose",
    "claude:sync": "node scripts/claude-sync.mjs --auto --verbose",
    "claude:status": "node scripts/claude-sync.mjs --status",
    "hooks:install": "node scripts/install-hooks.mjs",
    "validate": "node --check scripts/claude-sync.mjs && node --check scripts/install-hooks.mjs && node --check scripts/agent-budget.mjs && node --check scripts/agent-doctor.mjs && node --check scripts/agent-dry-run.mjs && node --check scripts/agent-handoff-only.mjs && node --check scripts/agent-next.mjs && node --check scripts/agent-worker-prompt.mjs && node --check scripts/dashboard-prepare.mjs && node --check scripts/credential-vault.mjs && node --check scripts/electron-login-window.mjs && node --check scripts/dashboard-runtime.mjs && node --check scripts/worker-launch-adapter.mjs && node --check scripts/dashboard-server.mjs && node --check scripts/desktop-artifact-info.mjs && node --check scripts/desktop-release.mjs && node --check scripts/agent-environment-setup.mjs && node --check scripts/user-environment-cycle-test.mjs && node --check apps/desktop/main.mjs && node --check scripts/agent-progress.mjs && node --check scripts/agent-route-model.mjs && node --check scripts/agent-scheduled-check.mjs && node --check scripts/agent-report.mjs && node --check scripts/validate-configs.mjs && node --check scripts/validate-quota-parser.mjs && node --check scripts/validate-runtime-race.mjs && node --check scripts/validate-e2e-server.mjs && node --check scripts/validate-integrations.mjs && node --check scripts/validate-remote-control.mjs && node scripts/validate-configs.mjs && node scripts/validate-quota-parser.mjs && node scripts/validate-integrations.mjs && node scripts/validate-remote-control.mjs && node scripts/validate-runtime-race.mjs && node scripts/validate-e2e-server.mjs",
    "postinstall": "node scripts/install-hooks.mjs && node scripts/claude-sync.mjs --auto --quiet-on-noop"
  },
  "build": {
    "appId": "com.agentapp.orchestrator",
    "productName": "AgentApp",
    "asar": true,
    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*",
      "**/*.node"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "afterPack": "scripts/after-pack.cjs",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "package.json",
      "apps/desktop/**/*",
      "apps/dashboard/dist/**/*",
      "scripts/credential-vault.mjs",
      "scripts/electron-login-window.mjs",
      "scripts/dashboard-runtime.mjs",
      "scripts/agent-environment-setup.mjs",
      "scripts/user-environment-cycle-test.mjs",
      "scripts/worker-launch-adapter.mjs",
      "scripts/dashboard-server.mjs",
      "tools/agent-orchestrator/**/*",
      ".claude-sync/**/*",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*",
      "!node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*.pdb",
      "!node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*.map",
      "!node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*.test.js",
      "!node_modules/@homebridge/node-pty-prebuilt-multiarch/src/**/*",
      "!node_modules/@homebridge/node-pty-prebuilt-multiarch/deps/**/*"
    ],
    "extraResources": [
      {
        "from": "build/setup-tools.cmd",
        "to": "setup-tools.cmd"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AgentApp",
      "uninstallDisplayName": "AgentApp ${version}",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dungbo92-eng",
        "repo": "agentapp",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "electron-updater": "^6.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "@homebridge/node-pty-prebuilt-multiarch"
    ]
  }
}
